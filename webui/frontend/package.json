{
  "name": "chatty-commander-webui",
  "version": "0.6.0",
  "description": "Web-based interface for ChattyCommander voice control system",
  "private": true,
  "type": "module",
  "dependencies": {
    "@floating-ui/react-dom": "^2.1.8",
    "@tanstack/react-query": "^5.101.0",
    "@types/node": "^20.9.0",
    "axios": "^1.6.2",
    "framer-motion": "^12.34.3",
    "lucide-react": "^0.562.0",
    "motion-dom": "^12.34.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.18.0",
    "recharts": "^2.8.0",
    "tailwind-merge": "^3.6.0"
  },
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "build": "vite build",
    "build:demo": "vite build --mode demo --outDir demo-dist",
    "serve": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "generate-docs": "playwright test tests/e2e/screenshots.spec.ts",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "type-check": "tsc --noEmit"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.58.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.5.0",
    "daisyui": "^4.12.10",
    "eslint": "^8.53.0",
    "eslint-config-react-app": "^7.0.1",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "vitest": "^4.0.18"
  }
}
