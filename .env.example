# Environment variables for ChattyCommander

# API Endpoints (configure for your deployment)
# CHATBOT_ENDPOINT=https://your-chatbot-server.example.com/

# API Authorization token
# BEARER_TOKEN=your_bearer_token_here

# OpenAI API Configuration (for LLM features)
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-3.5-turbo

# Database (for production deployments)
# DATABASE_URL=postgresql://user:password@localhost:5432/chatty_commander
# REDIS_URL=redis://localhost:6379/0

# Security
# JWT_SECRET=your-secure-random-secret-here
# CORS_ORIGINS=https://your-frontend.example.com

# --- Optional: dograh voice-call integration ---
# Client-side settings consumed by chatty-commander (integrations/dograh_client.py)
# DOGRAH_BASE_URL=http://localhost:8090            # dograh OSS API base URL
# DOGRAH_API_KEY=dgr_replace_me                    # API key minted by scripts/seed_dograh.py
# DOGRAH_SEED_WORKFLOW_ID=1                        # default workflow id used by seed/CI helpers
# DOGRAH_LIVE=0                                    # set 1 to enable opt-in live smoke tests

# Server-side settings for the docker-compose.dograh.yml overlay
# DOGRAH_OSS_JWT_SECRET=generate-a-64-hex-secret   # e.g. `openssl rand -hex 32`
# DOGRAH_SEED_PASSWORD=change_me                   # bootstrap admin password for seeding
# DOGRAH_REGISTRY=                                 # optional image registry prefix
# DOGRAH_FASTAPI_WORKERS=2
# DOGRAH_ENABLE_TELEMETRY=false
# DOGRAH_BACKEND_API_ENDPOINT=http://localhost:8090
# DOGRAH_MINIO_PUBLIC_ENDPOINT=http://localhost:9001

# Additional secrets or configuration options can be added below
# OTHER_SECRET=your_secret_value_here
