# Environment variables for ChattyCommander
#
# Zero-config principle: NOTHING here is required to boot the app with the
# default config. A variable only becomes REQUIRED when you explicitly enable
# the feature that needs it — startup then fails fast with a message listing
# every missing variable (see src/chatty_commander/app/env_validation.py).

# --- Advisors / LLM (REQUIRED when advisors.enabled=true with the OpenAI provider) ---
# OPENAI_API_KEY=sk-your-key-here                  # REQUIRED for advisors backed by OpenAI
#                                                  # (optional-but-recommended when a custom
#                                                  # OpenAI-compatible base_url is configured)
# OPENAI_BASE_URL=https://api.openai.com/v1       # custom OpenAI-compatible endpoint
# OPENAI_API_BASE=https://api.openai.com/v1       # legacy fallback for OPENAI_BASE_URL
# OPENAI_MODEL=gpt-3.5-turbo                       # default model for the OpenAI backend
# LLM_BACKEND=openai                               # preferred backend: openai | ollama
# OLLAMA_HOST=ollama:11434                         # local Ollama instance (host:port)

# --- Dograh voice-call integration (REQUIRED when any command uses a 'dograh_call' action) ---
# Client-side settings consumed by chatty-commander (integrations/dograh_client.py)
# DOGRAH_BASE_URL=http://localhost:8090            # REQUIRED with dograh_call actions: dograh OSS API base URL
# DOGRAH_API_KEY=dgr_replace_me                    # REQUIRED with dograh_call actions: key minted by scripts/seed_dograh.py
# DOGRAH_SEED_WORKFLOW_ID=1                        # default workflow id used by seed/CI helpers
# DOGRAH_LIVE=0                                    # set 1 to enable opt-in live smoke tests

# Server-side settings for the docker-compose.dograh.yml overlay
# DOGRAH_OSS_JWT_SECRET=generate-a-64-hex-secret   # e.g. `openssl rand -hex 32`
# DOGRAH_SEED_PASSWORD=change_me                   # bootstrap admin password for seeding
# DOGRAH_REGISTRY=                                 # optional image registry prefix
# DOGRAH_FASTAPI_WORKERS=2
# DOGRAH_ENABLE_TELEMETRY=false
# DOGRAH_BACKEND_API_ENDPOINT=http://localhost:8090
# DOGRAH_MINIO_PUBLIC_ENDPOINT=http://localhost:9001

# --- Web server / bridge ---
# CHATTY_API_KEY=replace-with-a-long-random-string # REQUIRED when web_server.auth_enabled=true (and not --no-auth):
#                                                  # value clients send as the X-API-Key header. Takes precedence over
#                                                  # auth.api_key in config. Startup fails fast if auth is enabled but
#                                                  # neither this nor auth.api_key is set (web/middleware/auth.py).
# CHATTY_JWT_SECRET=replace-with-a-64-hex-secret   # REQUIRED for the /api/v1/auth JWT login flow when auth.users is
#                                                  # configured; signs access tokens. Falls back to auth.jwt_secret.
# CHATTY_ENV=production                            # production refuses --no-auth (web/server.py)
# CHATTY_CORS_ORIGINS=http://localhost:3000        # comma-separated browser origins allowed by CORS; defaults to localhost-only (esp. in --no-auth mode)
# CHATTY_BRIDGE_TOKEN=your-bridge-token            # auth token for the /bridge endpoint (overrides web_server.bridge_token)
# CHATBOT_ENDPOINT=https://your-chatbot-server.example.com/   # override chatbot API endpoint
# HOME_ASSISTANT_ENDPOINT=http://homeassistant.local:8123/api # override Home Assistant endpoint
# CHATCOMM_HOST=0.0.0.0                            # web server host override
# CHATCOMM_PORT=8100                               # web server port override
# CHATCOMM_LOG_LEVEL=INFO                          # web-mode log level override

# --- General settings overrides (app/config.py) ---
# CHATCOMM_DEBUG=false                             # enable debug mode (true/yes/1)
# CHATCOMM_DEFAULT_STATE=idle                      # state on startup
# CHATCOMM_INFERENCE_FRAMEWORK=onnx                # inference framework
# CHATCOMM_START_ON_BOOT=false                     # start on system boot (true/yes/1)
# CHATCOMM_CHECK_FOR_UPDATES=true                  # automatic update checks

# --- Logging (utils/logging_config.py) ---
# LOG_LEVEL=INFO                                   # application log level
# LOG_FORMAT=plain                                 # plain | json

# --- Storage / paths ---
# CHATTY_AGENTS_STORE=~/.chatty_commander/agents.json  # agents store JSON file (web/routes/agents.py)
# XDG_CONFIG_HOME=~/.config                        # base dir for user config (cli/config.py)

# --- Desktop / GUI ---
# DISPLAY=:0                                       # X display for GUI mode and keypress actions

# --- Docker / compose only ---
# CHATTY_CONFIG=/app/config.json                   # config path inside the container (docker-compose.yml)
# POSTGRES_PASSWORD=changeme123                    # postgres service password (docker-compose.yml)

# --- Test/CI knobs ---
# CC_FAST=1                                        # reduced test mode
