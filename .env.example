# Environment variables for ChattyCommander

# API Endpoints (configure for your deployment)
# CHATBOT_ENDPOINT=https://your-chatbot-server.example.com/

# API Authorization token
# BEARER_TOKEN=your_bearer_token_here

# OpenAI API Configuration (for LLM features)
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-3.5-turbo

# Database (for production deployments)
# DATABASE_URL=postgresql://user:password@localhost:5432/chatty_commander
# REDIS_URL=redis://localhost:6379/0

# Security
# JWT_SECRET=your-secure-random-secret-here
# CORS_ORIGINS=https://your-frontend.example.com

# Additional secrets or configuration options can be added below
# OTHER_SECRET=your_secret_value_here

# --- Optional: Dograh voice-AI integration (see docker-compose.dograh.yml) ---
# Activate the overlay stack (append :docker-compose.speaches.yml for local STT/TTS):
# COMPOSE_FILE=docker-compose.yml:docker-compose.dograh.yml
# DOGRAH_REGISTRY=ghcr.io/dograh-hq
# DOGRAH_ENABLE_TELEMETRY=false
# DOGRAH_FASTAPI_WORKERS=1
# Required: 64-hex secret for dograh's OSS JWT auth (generate: openssl rand -hex 32)
# DOGRAH_OSS_JWT_SECRET=
# DOGRAH_BACKEND_API_ENDPOINT=http://localhost:8020
# DOGRAH_MINIO_PUBLIC_ENDPOINT=http://localhost:9010
# CC -> dograh client settings (key issued by scripts/seed_dograh.py)
# DOGRAH_BASE_URL=http://localhost:8020
# DOGRAH_API_KEY=
