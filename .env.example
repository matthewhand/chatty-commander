# Environment variables for ChattyCommander
# Copy this file to .env and fill in your actual values

# API Endpoints
CHATBOT_ENDPOINT=http://localhost:8000

# API Authorization token (generate a secure token)
BEARER_TOKEN=generate_secure_random_token_here

# Bridge token for internal service communication (generate a secure token)
BRIDGE_TOKEN=generate_secure_random_token_here

# Additional secrets or configuration options can be added below
# OTHER_SECRET=your_secret_value_here
