# .env.schema
# Schema for required and optional environment variables for ChattyCommander.
# Copy .env.example to .env and fill with secure values. Never commit .env.
# Use this as reference for validation (see Phase 1 roadmap: secrets validation).
#
# Security notes:
# - All secrets must be strong random values (use openssl rand -hex 32).
# - Different values per environment (dev/staging/prod).
# - For production, prefer secret managers over .env files.
# - Startup validation recommended (fail fast on missing required).

# === Core API / Endpoints (required for full features) ===
# CHATBOT_ENDPOINT=https://your-chatbot-server.example.com/
# BEARER_TOKEN=your_bearer_token_here   # Legacy? See auth config

# === OpenAI / LLM (required for LLM-dependent features) ===
OPENAI_API_KEY=sk-your-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-3.5-turbo

# === Database / Persistence (production) ===
# DATABASE_URL=postgresql://user:password@localhost:5432/chatty_commander
# REDIS_URL=redis://localhost:6379/0

# === Security (critical) ===
JWT_SECRET=your-secure-random-secret-here   # For JWT if/when implemented
# Note: Current auth primarily uses API key (X-API-Key header) + optional no_auth mode.
# BEARER_TOKEN and BRIDGE_TOKEN also referenced in SECURITY.md for generation.
BRIDGE_TOKEN=your-secure-bridge-token-here

# === CORS / Network ===
# CORS_ORIGINS=https://your-frontend.example.com,http://localhost:3000

# === Auth Config (via config.json or env overrides; see web/middleware/auth.py) ===
# Example for config-driven: auth.api_key in your config
# API_KEY=your_api_key_for_X-API-Key   # Alternative to config

# === Other / Optional ===
# POSTGRES_PASSWORD=... (for docker-compose examples only; use secrets)
# GRAFANA_PASSWORD=...
# HOME_ASSISTANT_URL=...

# Additional variables may be added by features (e.g. voice, cv, providers).
# For full list, see .env.example, SECURITY.md, and source (grep for os.getenv|environ|getenv).

# Recommended: Implement SECRETS_VALIDATION=true to enforce required vars at startup.
